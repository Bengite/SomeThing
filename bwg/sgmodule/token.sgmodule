#!name=eworkplat Token Grabber
#!desc=从 eworkplat 的请求头中自动提取 Authorization Token

[MITM]
hostname = %APPEND% eworkplat.foxconn.com

[Script]
# 当匹配到任何 eworkplat 相关的 URL 时触发脚本
GetToken = type=http-request,pattern=eworkplat,script_path=https://raw.githubusercontent.com/Bengite/SomeThing/refs/heads/main/bwg/sgmodule/get_token.js,requires-body=false
