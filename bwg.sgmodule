#!name=BWG Traffic Panel
#!desc=搬瓦工多台 VPS 流量監控面板。請在參數中填寫: 名稱#VEID#APIKEY，多台用逗號隔開。
#!category=Monitor

#!arguments=ids:name#id#key

[Panel]
BWG_Monitor = script-name=BWG_Stats, update-interval=3600

[Script]
# 將這裡的 argument 替換為你的真實數據   香港#123456#KEY_AAA,美國#789012#KEY_BBB
BWG_Stats = type=generic, script-path=https://raw.githubusercontent.com/Bengite/SomeThing/refs/heads/main/bwgarea.js, argument={{{ids}}}
